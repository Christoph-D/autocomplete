{
  "name": "autocomplete",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "DavidAnson.vscode-markdownlint",
        "ms-vscode.extension-test-runner",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "prettier.proseWrap": "always",
        "markdownlint.config": {
          "no-duplicate-heading": {
            "siblings_only": true
          }
        },
        "files.insertFinalNewline": true
      }
    }
  },
  "workspaceFolder": "/workspaces/autocomplete",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/autocomplete,type=bind,consistency=cached",
  "remoteUser": "ubuntu",
  "mounts": [
    "source=config-autocomplete,target=/home/ubuntu/persistent-config,type=volume",
    "source=/etc/localtime,target=/usr/share/zoneinfo/hostlocaltime,type=bind,readonly"
  ],
  "postCreateCommand": "bash .devcontainer/setup.sh"
}
